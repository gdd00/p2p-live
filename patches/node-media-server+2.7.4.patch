@@ -63,6 +63,53 @@ class NodeHttpServer {
       app.use('/api/streams', streamsRoute(context));
       app.use('/api/server', serverRoute(context));
       app.use('/api/relay', relayRoute(context));
+      app.get('/api/live/status', (req, res) => {
+        const streamPath = typeof req.query.stream === 'string' ? req.query.stream : '/live/stream';
+        const playheadMs = Number(req.query.playheadMs);
+        const hasPlayhead = Number.isFinite(playheadMs);
+        const state = context.liveStreams && context.liveStreams.get(streamPath);
+        const now = Date.now();
+
+        if (!state) {
+          res.json({
+            ok: false,
+            streamPath,
+            now,
+            active: false,
+            message: 'stream not found',
+          });
+          return;
+        }
+
+        const liveEdgeClockMs = state.lastFrameClock ?? state.lastVideoClock;
+        const liveEdgeObservedAt = state.lastFrameAt ?? state.lastVideoAt;
+        let estimatedFrameAt = null;
+        let delayMs = null;
+
+        if (hasPlayhead && liveEdgeClockMs != null && liveEdgeObservedAt != null) {
+          const lagMs = Math.max(0, liveEdgeClockMs - playheadMs);
+          estimatedFrameAt = liveEdgeObservedAt - lagMs;
+          delayMs = Math.max(0, now - estimatedFrameAt);
+        }
+
+        res.json({
+          ok: true,
+          streamPath,
+          active: !!state.active,
+          now,
+          publishedAt: state.publishedAt ?? null,
+          endedAt: state.endedAt ?? null,
+          lastVideoClock: state.lastVideoClock ?? null,
+          lastVideoAt: state.lastVideoAt ?? null,
+          lastFrameClock: state.lastFrameClock ?? null,
+          lastFrameAt: state.lastFrameAt ?? null,
+          liveEdgeClockMs,
+          liveEdgeObservedAt,
+          playheadMs: hasPlayhead ? playheadMs : null,
+          estimatedFrameAt,
+          delayMs,
+        });
+      });
     }
 
     app.use(Express.static(path.join(__dirname + '/public')));
